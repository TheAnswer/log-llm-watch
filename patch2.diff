+def build_incident_context(
+    conn: sqlite3.Connection,
+    incident_id: int,
+    event_limit: int = 20,
+    nearby_limit: int = 100,
+    similar_limit: int = 10,
+    minutes_before: int = 2,
+    minutes_after: int = 5,
+) -> dict[str, Any]:
+    conn.row_factory = sqlite3.Row
+
+    incident = conn.execute(
+        "SELECT * FROM incidents WHERE id = ?",
+        (incident_id,),
+    ).fetchone()
+    if not incident:
+        raise HTTPException(status_code=404, detail="Incident not found")
+
+    representative_events = get_representative_incident_events(
+        conn,
+        incident_id=incident_id,
+        limit=event_limit,
+    )
+
+    try:
+        first_seen_dt = datetime.fromisoformat(str(incident["first_seen"]).replace("Z", "+00:00"))
+    except Exception:
+        first_seen_dt = utcnow()
+
+    try:
+        last_seen_dt = datetime.fromisoformat(str(incident["last_seen"]).replace("Z", "+00:00"))
+    except Exception:
+        last_seen_dt = first_seen_dt
+
+    nearby_start = (first_seen_dt - timedelta(minutes=max(0, minutes_before))).isoformat()
+    nearby_end = (last_seen_dt + timedelta(minutes=max(0, minutes_after))).isoformat()
+
+    nearby_events = conn.execute(
+        """
+        SELECT id, ts, created_at, source, host, container, stream, level,
+               severity_norm, event_class, dependency, message, incident_id
+        FROM events
+        WHERE ts >= ? AND ts <= ?
+        ORDER BY ts ASC, id ASC
+        LIMIT ?
+        """,
+        (nearby_start, nearby_end, max(1, min(nearby_limit, 500))),
+    ).fetchall()
+
+    similar_incidents = conn.execute(
+        """
+        SELECT id, status, severity, title, event_class, first_seen, last_seen,
+               event_count, affected_nodes, affected_services, root_cause_candidates,
+               summary, metadata
+        FROM incidents
+        WHERE primary_fingerprint = ?
+          AND id != ?
+        ORDER BY last_seen DESC
+        LIMIT ?
+        """,
+        (
+            incident["primary_fingerprint"],
+            incident_id,
+            max(1, min(similar_limit, 50)),
+        ),
+    ).fetchall()
+
+    return {
+        "incident": {
+            "id": incident["id"],
+            "status": incident["status"],
+            "severity": incident["severity"],
+            "title": incident["title"],
+            "event_class": incident["event_class"],
+            "primary_fingerprint": incident["primary_fingerprint"],
+            "first_seen": incident["first_seen"],
+            "last_seen": incident["last_seen"],
+            "event_count": incident["event_count"],
+            "affected_nodes": safe_json_loads(incident["affected_nodes"], []),
+            "affected_services": safe_json_loads(incident["affected_services"], []),
+            "root_cause_candidates": safe_json_loads(incident["root_cause_candidates"], []),
+            "summary": incident["summary"] or "",
+            "metadata": safe_json_loads(incident["metadata"], {}),
+        },
+        "representative_events": [dict(row) for row in representative_events],
+        "nearby_events": [dict(row) for row in nearby_events],
+        "similar_incidents": [
+            {
+                "id": row["id"],
+                "status": row["status"],
+                "severity": row["severity"],
+                "title": row["title"],
+                "event_class": row["event_class"],
+                "first_seen": row["first_seen"],
+                "last_seen": row["last_seen"],
+                "event_count": row["event_count"],
+                "affected_nodes": safe_json_loads(row["affected_nodes"], []),
+                "affected_services": safe_json_loads(row["affected_services"], []),
+                "root_cause_candidates": safe_json_loads(row["root_cause_candidates"], []),
+                "summary": row["summary"] or "",
+                "metadata": safe_json_loads(row["metadata"], {}),
+            }
+            for row in similar_incidents
+        ],
+        "window": {
+            "nearby_start": nearby_start,
+            "nearby_end": nearby_end,
+            "minutes_before": minutes_before,
+            "minutes_after": minutes_after,
+        },
+    }
