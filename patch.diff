+def enrich_event(event: dict[str, str]) -> dict[str, str]:
+    enriched = dict(event)
+    enriched["ts"] = utcnow().isoformat()
+    enriched["service"] = infer_service(enriched.get("container", ""))
+    enriched["host_type"] = infer_host_type(enriched.get("host", ""))
