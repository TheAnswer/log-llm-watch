+def infer_labels(host: str, container: str) -> dict[str, Any]:
+    labels: dict[str, Any] = {}
+    node_meta = NODE_METADATA.get(host or "", {})
+    svc_meta = SERVICE_METADATA.get(container or "", {})
+    if node_meta:
+        labels["node_meta"] = node_meta
+    if svc_meta:
+        labels["service_meta"] = svc_meta
