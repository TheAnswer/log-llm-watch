 def normalize_message(msg: str) -> str:
     msg = re.sub(r"\b\d{4}-\d{2}-\d{2}[T ][0-9:\.\+\-Z]+\b", "<ts>", msg)
+    msg = re.sub(r"\b(?:\d{1,3}\.){3}\d{1,3}\b", "<ip>", msg)
+    msg = re.sub(r":\d{2,5}\b", ":<port>", msg)
