 def close_stale_incidents() -> None:
     cfg = CONFIG.get("incidents", {})
     stale_minutes = int(cfg.get("close_after_minutes", 30))
     cutoff = (utcnow() - timedelta(minutes=stale_minutes)).isoformat()
     with db() as conn:
         conn.execute(
             """
             UPDATE incidents
             SET status = 'closed',
                 updated_at = ?
             WHERE status = 'open'
               AND last_seen < ?
             """,
             (utcnow().isoformat(), cutoff),
         )
         conn.commit()
