+def get_representative_incident_events(
+    conn: sqlite3.Connection,
+    incident_id: int,
+    limit: int = 20,
+) -> list[sqlite3.Row]:
+    """
+    Return a compact but representative sample of events for an incident:
+    earliest few, latest few, and most recent remainder if needed.
+    """
+    limit = max(1, min(limit, 100))
+    conn.row_factory = sqlite3.Row
+
+    if limit <= 6:
+        return conn.execute(
+            """
+            SELECT id, ts, created_at, source, host, container, stream, level,
+                   severity_norm, event_class, dependency, message,
+                   message_template, canonical_fingerprint
+            FROM events
+            WHERE incident_id = ?
+            ORDER BY ts ASC, id ASC
+            LIMIT ?
+            """,
+            (incident_id, limit),
+        ).fetchall()
+
+    early_n = min(5, limit // 2)
+    late_n = min(5, max(1, limit - early_n))
+
+    early = conn.execute(
+        """
+        SELECT id, ts, created_at, source, host, container, stream, level,
+               severity_norm, event_class, dependency, message,
+               message_template, canonical_fingerprint
+        FROM events
+        WHERE incident_id = ?
+        ORDER BY ts ASC, id ASC
+        LIMIT ?
+        """,
+        (incident_id, early_n),
+    ).fetchall()
+
+    late = conn.execute(
+        """
+        SELECT id, ts, created_at, source, host, container, stream, level,
+               severity_norm, event_class, dependency, message,
+               message_template, canonical_fingerprint
+        FROM events
+        WHERE incident_id = ?
+        ORDER BY ts DESC, id DESC
+        LIMIT ?
+        """,
+        (incident_id, late_n),
+    ).fetchall()
+
+    merged: dict[int, sqlite3.Row] = {}
+    for row in early:
+        merged[int(row["id"])] = row
+    for row in late:
+        merged[int(row["id"])] = row
+
+    rows = sorted(merged.values(), key=lambda r: (r["ts"] or "", r["id"]))
+    if len(rows) >= limit:
+        return rows[:limit]
+
+    remaining = limit - len(rows)
+    existing_ids = sorted(merged.keys())
+
+    if existing_ids:
+        placeholders = ",".join("?" for _ in existing_ids)
+        sql = f"""
+        SELECT id, ts, created_at, source, host, container, stream, level,
+               severity_norm, event_class, dependency, message,
+               message_template, canonical_fingerprint
+        FROM events
+        WHERE incident_id = ?
+          AND id NOT IN ({placeholders})
+        ORDER BY ts DESC, id DESC
+        LIMIT ?
+        """
+        params: list[Any] = [incident_id, *existing_ids, remaining]
+    else:
+        sql = """
+        SELECT id, ts, created_at, source, host, container, stream, level,
+               severity_norm, event_class, dependency, message,
+               message_template, canonical_fingerprint
+        FROM events
+        WHERE incident_id = ?
+        ORDER BY ts DESC, id DESC
+        LIMIT ?
+        """
+        params = [incident_id, remaining]
+
+    more = conn.execute(sql, params).fetchall()
+    for row in more:
+        merged[int(row["id"])] = row
+
+    return sorted(merged.values(), key=lambda r: (r["ts"] or "", r["id"]))[:limit]
+
